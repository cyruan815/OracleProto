# =============================================================
#  Forecast Evaluation - environment variable configuration
#
#  Setup: copy this file to .env, fill in the required keys, then run: python evaluation.py
#
#  Required keys:
#    - LLM_API_KEY, LLM_BASE_URL, MODELS
#    - TAVILY_API_KEY                              (only when ENABLE_WEB_SEARCH=true)
#    - LEAK_DETECTOR_API_KEY, LEAK_DETECTOR_MODEL  (only when ENABLE_SEARCH_LEAK_FILTER=true)
#  Every other empty field below is an intentional default (auto-derived or "do nothing").
#
#  This project only requires LLM endpoints to be "OpenAI-compatible"
#  (POST /chat/completions with tool_calls support). Any provider conforming
#  to that protocol can be used directly.
# =============================================================

# -------- LLM Endpoint (OpenAI-compatible) --------
LLM_API_KEY=
LLM_BASE_URL=

# Comma-separated list of models to evaluate (Cartesian product: every model runs all questions x all samples).
# Each slug must be a native slug supported by the provider behind the LLM_BASE_URL above.
# Do not append ":online" and do not enable any provider-native browsing.
MODELS=

# Model training cutoff: (q, model) pairs whose question end_time <= cutoff are skipped and marked skipped_training_cutoff.
# Format: "<model_slug>=YYYY-MM-DD" with multiple entries comma-separated. Models not declared here are not filtered.
# Please verify cutoffs against the actual models you are using.
MODEL_TRAINING_CUTOFFS=

# LLM call parameters
# max_tokens already provides budget for reasoning + output (reasoning models often consume 3-8k reasoning tokens)
LLM_MAX_TOKENS=12000

# Per-model override of the token-limit field name used in the request body. Default `max_tokens`; some providers
# have deprecated max_tokens and require max_completion_tokens, otherwise they return 400.
# Format: "<model_slug>=max_completion_tokens" with multiple entries comma-separated. Undeclared models use the default.
# Only max_tokens | max_completion_tokens are allowed values.
MODEL_MAX_TOKENS_PARAM=
LLM_TIMEOUT_S=240
LLM_TEMPERATURE=0.7
LLM_TOP_P=1.0

# Per-model omission of individual sampling fields. Use when a non-reasoning model rejects
# `temperature` and `top_p` together (e.g., providers returning 400 with "cannot both be specified")
# but still accepts custom sampling on the kept field. Format: "<model_slug>=temperature" or
# "<model_slug>=top_p" with multiple entries comma-separated; the same slug repeated accumulates fields,
# e.g. "foo=temperature,foo=top_p" omits both (in which case prefer LLM_REASONING_MODEL_PATTERNS instead).
# Allowed values: temperature | top_p. Undeclared models send both fields as usual.
MODEL_OMIT_SAMPLING_FIELDS=

# List of reasoning-model slug substrings (case-insensitive): when matched, calls **omit** temperature / top_p.
# Reasoning models often return 400 for custom sampling parameters; matching by substring also catches
# provider-prefixed slugs (e.g. any slug containing "r1" is filtered).
LLM_REASONING_MODEL_PATTERNS=o1,o3,o4,r1,qwq

# LLM concurrency & retry
# Start conservative (most providers' free/basic tiers are ~60 RPM); raise after observing 429s.
LLM_MAX_CONCURRENCY=5
LLM_RETRY_MAX=5
LLM_BACKOFF_NETWORK_S=2,5,15,30,60
LLM_BACKOFF_RATE_LIMIT_S=10,30,60,120,300
LLM_BACKOFF_SERVER_5XX_S=5,15,30,60,120

# -------- Web Search Master Switch --------
# Master switch for web search. Default true = wire the homemade web_search tool into the ReAct loop (using Tavily).
# When false: LLM requests carry no tool schema, ReAct degrades to single-step direct answers, Tavily
# is never invoked (TAVILY_API_KEY can be left empty in this mode).
ENABLE_WEB_SEARCH=true

# -------- Tavily Search --------
# In this section TAVILY_MAX_RESULTS and the REACT_MAX_SEARCH_CALLS field in the ReAct section below
# support grid search: when one or more values are provided, the system automatically expands an R x C Cartesian product,
# writing one independent .db file per (R, C) cell; a single value (no comma) degrades to current single-cell behavior.
#
# TAVILY_API_KEY supports a single value or CSV multi-value (multiple keys recommended to increase total quota and balance usage):
#   single:  TAVILY_API_KEY=tvly-aaa
#   multi:   TAVILY_API_KEY=tvly-aaa,tvly-bbb,tvly-ccc
# With multiple keys, TavilyKeyPool performs least-used scheduling: each request picks the healthiest key with the lowest usage,
# 401/403 are permanently blacklisted, 429 enters a temporary cooldown (auto-recovers after TAVILY_KEY_COOLDOWN_S seconds).
# Cross-run fairness relies on a random starting offset at startup, so we don't always burn keys[0] first.
# To exercise every key, set SEARCH_RETRY_MAX >= number of keys (default 3; raise it when using multiple keys).
TAVILY_API_KEY=

# Seconds to temporarily blacklist a single key when it hits 429 / quota-exceeded (no effect with single-key config).
# 0 = no cooldown (rely on acquire ordering only, but easily ineffective during dense bursts);
# 60 (default) is a common Tavily rate-limit window and usually long enough to recover.
TAVILY_KEY_COOLDOWN_S=60

# Number of results returned per Tavily search (R axis).
#   single example:  TAVILY_MAX_RESULTS=5
#   grid example:    TAVILY_MAX_RESULTS=5,10
# Multi-values cause every real model x every C value to run |R_list| times; .db filenames carry the __r{R}__c{C} suffix.
TAVILY_MAX_RESULTS=5

# Tavily search_depth (retrieval intensity defined in Tavily official docs):
#   basic    - 1 credit/call, title + content summary, suitable for fact lookups (recommended, default)
#   advanced - 2 credits/call, longer content + higher recall, suitable for long-tail events
# A single prediction averages 3-5 searches; default basic keeps credit consumption under control.
TAVILY_SEARCH_DEPTH=basic

# Tavily include_raw_content: whether to return page body and in what format
#   false    - return only ~1-2k chars/result summary (content field), most context-economical
#   markdown - full page markdown (single result can reach 40k+ chars), most informative (default)
#   text     - full page plain text, roughly 2/3 the size of markdown
# Note: single-result raw_content is large; always set TAVILY_RAW_CONTENT_MAX_CHARS to truncate.
# Compatibility: legacy true is equivalent to markdown, legacy false stays as false.
TAVILY_INCLUDE_RAW_CONTENT=markdown

# Truncation length for single-result raw_content (chars). Only effective when TAVILY_INCLUDE_RAW_CONTENT != false.
# 0 = no truncation (caution: 5 results per search can total >200k chars and easily blow up the LLM context).
# 8000 ~= ~2k tokens per result, ~10k tokens for 5 results, leaving room for reasoning + history.
TAVILY_RAW_CONTENT_MAX_CHARS=8000

# Tavily include_answer: quick answer from Tavily's internal model (evaluation-purity consideration)
#   false    - do not return (default, recommended)
#              The evaluation aims to test the evaluated model's own judgment when reading results;
#              enabling answer introduces a "second LLM"'s judgment, which compresses the gap between
#              strong and weak models and pollutes evaluation results.
#   basic    - one-sentence quick answer
#   advanced - multi-paragraph detailed answer (extra credits)
TAVILY_INCLUDE_ANSWER=false

# end_date = question.end_time + offset. Default -1 (the day before, to avoid same-day event leakage).
TAVILY_END_DATE_OFFSET_DAYS=-1

# Tavily concurrency & retry
SEARCH_MAX_CONCURRENCY=5
SEARCH_RETRY_MAX=3
SEARCH_BACKOFF_S=2,5,15

# -------- ReAct Loop --------
# Maximum number of LLM <-> system interaction rounds within a sample. With reflection protocol or nudge enabled,
# per-question rounds run 2-4 more than single-step direct answers, so leave ample headroom (12 by default).
REACT_MAX_STEPS=12
# Hard upper bound on cumulative web_search calls within a single sample (C axis). Subsequent tool calls
# beyond this limit return 'search budget exceeded'. The reflection protocol encourages multi-angle retrieval
# but still respects this budget to prevent runaway billing.
#   single example:  REACT_MAX_SEARCH_CALLS=8
#   grid example:    REACT_MAX_SEARCH_CALLS=1,3,5,8
# With multiple values, the dispatcher derives a cell-local Settings sub-view per cell; what react.py sees
# for REACT_MAX_SEARCH_CALLS is always the cell's single int value. When REACT_MIN_SEARCH_CALLS conflicts with
# a cell's C, it is silently clamped (effective_min = min(MIN, C)); see design decision D4.
REACT_MAX_SEARCH_CALLS=8

# Master switch for the reflection protocol (recommended true).
# When enabled, multi-step reasoning scaffolding is appended to the end of the user prompt (decompose ->
# list >=3 search angles -> reflect after each search -> cross-validate -> reverse self-check -> emit
# confidence). It uses prompt engineering to pull the model from "answer after one search" to
# "multi-angle retrieval + explicit reflection". This is the preferred method - significantly improves
# tool calls and depth of thought without a hard minimum count.
# Note: protocol text does not enter dataset_metadata, so prompt_templates_hash stays unchanged, but the
# fully rendered user message lands in each sample's user_prompt field, fully reproducible.
# Set false to fall back to legacy behavior (for control experiments).
REACT_REFLECTION_PROTOCOL=true

# Soft minimum search count (fallback floor, off by default).
# 0 = disabled. >0 = when the LLM tries to give a final answer but cumulative web_search count < this value,
# inject a user nudge asking it to continue retrieval from a new angle before answering. Only enable when
# the reflection protocol alone is insufficient to drive the model, e.g., for some smaller models that refuse
# multi-step reasoning. Constrained by REACT_MAX_SEARCH_CALLS upper bound (cannot exceed it).
# Recommended values: 0 (default, let the protocol drive naturally) or 2-3 (enforce a floor).
REACT_MIN_SEARCH_CALLS=0

# Maximum number of nudges per sample, to prevent infinite nudge loops between model and system.
# REACT_MAX_STEPS is still the hard ceiling. 0 = nudges fully disabled (equivalent to setting REACT_MIN_SEARCH_CALLS to 0).
REACT_MAX_NUDGES=2

# v5.1 harness-resilience switches (off by default; off to run control experiments). See
# openspec/changes/harness-resilience-v1/proposal.md
# REACT_FINAL_ANSWER_RETRY=true: when the loop ends normally but final_raw=="", call the LLM once more with tools=[]
#   to force it to emit \boxed{...}. Backstop for residual empty answers; does not count toward nudges_used,
#   counted into react_steps + step_metrics.
# REACT_BUDGET_EXCEEDED_DROP_TOOLS=true: once cumulative web_search >= REACT_MAX_SEARCH_CALLS, subsequent
#   LLM calls drop tools=[] (remove the web_search schema), forcing the model to produce content directly to wrap up.
REACT_FINAL_ANSWER_RETRY=false
REACT_BUDGET_EXCEEDED_DROP_TOOLS=true

# force-final-answer-near-limit-v1: front-loads "running out of steps" at the prompt layer, replacing the
# prior post-hoc REACT_FINAL_ANSWER_RETRY backstop.
# REACT_BUDGET_AWARENESS_PROTOCOL=true: append a budget-awareness section at the end of the user prompt,
#   informing the model of total steps + total searches so it reserves the last step for a \boxed{...} answer
#   (overall planning awareness).
# REACT_FORCE_FINAL_ANSWER_NEAR_LIMIT=true: actively inject a user message as the loop nears the limit:
#   - From step (N - LOOKAHEAD) to second-to-last: soft reminder, tool_calls still allowed, gives the model
#     a final decisive search opportunity.
#   - Last step: hard wrap-up text + tools=[], forcing content-only output of \boxed{...}.
#   Injected messages do not count toward nudges_used but land in messages_trace for auditing.
# REACT_FORCE_FINAL_ANSWER_LOOKAHEAD: how many steps before the limit to start intervening. 1 = hard switch
#   only on the last step, 2 = soft reminder at second-to-last + hard switch on last (default; lets the model
#   plan globally with a graded transition). Must be >=1 and <= REACT_MAX_STEPS.
REACT_BUDGET_AWARENESS_PROTOCOL=true
REACT_FORCE_FINAL_ANSWER_NEAR_LIMIT=true
REACT_FORCE_FINAL_ANSWER_LOOKAHEAD=2

# -------- Grid search anchors (optional) --------
# When .env is configured with multi-value R / C, the paper main figure pins R = GRID_DEFAULT_R to draw
# the BI vs C curve; similarly GRID_DEFAULT_C controls the C anchor for the BI vs R curve. Must belong to
# the corresponding list (validated at startup).
# When left empty, plot_analysis.py defaults to the first value of each list.
GRID_DEFAULT_R=
GRID_DEFAULT_C=

# -------- Structured Confidence Protocol (v4 probabilistic) --------
# Master switch for the structured confidence protocol (v4 probabilistic analysis).
# When enabled, a belief protocol section is appended at the end of the user prompt (after the reflection
# protocol), requiring the LLM to emit, before \boxed{...}, <belief>{"probabilities": ..., "confidence": ...,
# "key_evidence": [...], "counterevidence": [...], "decision_rule": "..."}</belief>
# as strict JSON. Independent of the reflection protocol: does not enter prompt_templates_hash; fingerprinted
# via run_meta.belief_protocol_*. Default false, byte-for-byte identical to v3 user message.
# Before enabling, pilot a couple of candidate models and confirm belief_parse_ok >= 0.9 before full rollout.
BELIEF_PROTOCOL=false

# -------- Search Leak Filter (Stage 2 detector) --------
# search-leak-filter-v1: before each Tavily-returned result reaches the main LLM, an independent
# detector LLM audits whether the content references events after the cutoff (q.end_time + offset).
# verdict=drop removes the entire item. Defends against semantic leakage that Tavily's end_date filter
# does not cover (e.g., page bodies that mention future events).
#
# Enabled by default (strict). Activation requirements:
#   1) ENABLE_WEB_SEARCH=true (otherwise the detector path is dead code)
#   2) LEAK_DETECTOR_API_KEY / LEAK_DETECTOR_MODEL must be filled in
# To disable the leak filter, set ENABLE_SEARCH_LEAK_FILTER=false (the pipeline reverts byte-for-byte
# to pre-leak-filter behavior).
ENABLE_SEARCH_LEAK_FILTER=true

# Detector's own OpenAI-compatible endpoint config, fully decoupled from LLM_*.
# Recommend choosing a more advanced model than the evaluated models (better understanding, fewer false negatives).
# When LEAK_DETECTOR_BASE_URL is empty, falls back to LLM_BASE_URL.
LEAK_DETECTOR_API_KEY=
LEAK_DETECTOR_BASE_URL=
# Detector model slug. ":online" suffix is not allowed (provider-native browsing protection).
LEAK_DETECTOR_MODEL=

# Detector call parameters
LEAK_DETECTOR_TIMEOUT_S=60
LEAK_DETECTOR_TEMPERATURE=0.0
LEAK_DETECTOR_MAX_TOKENS=512

# Detector retry strategy (fully independent of the main LLM, prevents detector misbehavior from affecting main LLM quota).
# AUTH errors (401/403) do not count as retries; fail-closed immediately.
LEAK_DETECTOR_RETRY_MAX=3
LEAK_DETECTOR_BACKOFF_S=2,5,15

# Detector failure action: drop = remove the result item (default, strict); keep = pass through
# (escape hatch, for control experiments; not recommended for production runs).
LEAK_DETECTOR_FAIL_ACTION=drop

# Concurrent audit count for the N results within a single web_search call (per-item audit + asyncio.gather).
LEAK_DETECTOR_CONCURRENCY=5

# Manual version label; sha256(prompt_template) is auto-hashed into run_meta.config_snapshot.
# Changing the prompt always changes the hash; this label is purely human-readable.
LEAK_DETECTOR_PROMPT_VERSION=v1

# -------- Composite difficulty coefficients --------
# The composite difficulty coefficient factorises along two orthogonal axes:
# a question-type prior (0.15, 0.15, 0.70) over {yes_no, binary_named,
# multiple_choice} and a within-mc answering-mode split (0.40, 0.60) over
# {single, multi}. Multiplying the two yields the four scoring buckets
# {yes_no, binary_named, mc_single, mc_multi} with weights
# (0.15, 0.15, 0.28, 0.42), summing to one. The yes/no and binary_named
# buckets carry a degenerate single-mode share of 1, so their composite
# coefficients coincide with their question-type priors. For all metrics the
# analysis layer applies "compute per bucket -> synthesise by weight ->
# drop missing buckets and renormalise", writing
# runs/{run_id}/analysis/per_model_composite.csv (column names align
# one-to-one with per_model_summary.csv).
#
# Formula: composite_metric = sum(w_b * v_b) / sum(w_b), summed only over
# buckets where v_b is not None (missing buckets are excluded and weights
# renormalised; not treated as 0).
#
# Allowed bucket keys: yes_no | binary_named | mc_single | mc_multi.
# Missing buckets are treated as weight 0 (i.e., "do not participate in
# synthesis"), but at least one weight must be > 0.
COMPOSITE_WEIGHTS=yes_no=0.15,binary_named=0.15,mc_single=0.28,mc_multi=0.42

# Per-metric overrides (optional): of the form
# "fss=yes_no=0.05,binary_named=0.05,mc_single=0.20,mc_multi=0.70;
#  cohen_kappa=yes_no=0.10,binary_named=0.10,mc_single=0.30,mc_multi=0.50"
# Semicolons separate different metrics; commas separate buckets within the
# same metric. Metrics not listed fall back to the global COMPOSITE_WEIGHTS.
# Misspelled metric names raise during the analysis stage. Known metrics:
# all data columns of per_model_summary.csv, including v3 accuracy
# (pass_at_1_avg / resolvable_rate / pass_any_at_n / at_least_majority_at_n /
# at_least_all_at_n / exam_score_at_n_avg / majority_vote_accuracy /
# parse_failure_rate / error_rate / cutoff_skip_rate /
# final_answer_retry_rate / count columns / behavioral cost columns), v5
# discrete (fss / fss_pe_mean / cohen_kappa / hamming_score / fleiss_kappa /
# mean_entropy / vci / mvg), v4 probabilistic (bi / bi_dec / nll / mbs /
# abi_crowd / abi_uniform / fallback_share).
COMPOSITE_WEIGHT_OVERRIDES=

# -------- Sampling --------
# When interpreted via the exam_score_at_n_avg metric, SAMPLING_N is equivalent to "number of independent test runs"
# (each test scores 0~1 independently, final score is the arithmetic mean).
SAMPLING_N=5

# -------- Run / Resume --------
# Leave empty to auto-generate YYYYMMDD-HHMMSS-{4-char short uuid}. Use the same run_id to resume from checkpoint.
RUN_ID=
RESUME=true

# -------- Database --------
# SOURCE_DB: path to the question bank sqlite file. The bundled example dataset is forecast_eval_set_example.db
# (319 questions, 2026-01-15 ~ 2026-04-14). To use your own dataset, swap this path — the table schema must stay consistent.
SOURCE_DB=./forecast_eval_set_example.db

# SOURCE_TABLE: question bank table name inside SOURCE_DB. The bundled dataset uses forecast_eval_set_example;
# when swapping to your own dataset, change this to your own table name (the loader uses this parameter to dynamically select the FROM table).
# Table schema must include: id / choice_type / question_type / event / options / answer / end_time
# (see FRAME.md S2.1 for field semantics). Table name only allows valid SQLite identifiers [A-Za-z_][A-Za-z0-9_]*,
# to prevent SQL injection.
SOURCE_TABLE=forecast_eval_set_example

# Each evaluation creates an independent {run_id}/ subdirectory under RUNS_ROOT (db/ / analysis/ / logs/).
# Each model occupies one sqlite file under db/; statistics are written to analysis/ after the evaluation finishes.
RUNS_ROOT=./runs
DB_COMMIT_BATCH=10
# false skips storing the full messages trace, reducing db size by ~80%
WRITE_MESSAGES_TRACE=true

# -------- Logging --------
LOG_LEVEL=INFO
LOG_DIR=./logs
