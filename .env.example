# =============================================================
#  Forecast Evaluation — 环境变量配置
#  复制为 .env 后填入 API Key 即可运行: python evaluation.py
#
#  本工程仅要求 LLM 端点 "OpenAI 兼容" (POST /chat/completions 支持
#  tool_calls). 任意符合该协议的 provider 都可直接使用.
# =============================================================

# -------- LLM Endpoint (OpenAI-compatible) --------
# LLM_BASE_URL 示例:
#   OpenRouter:   https://openrouter.ai/api/v1
#   阿里百炼:     https://dashscope.aliyuncs.com/compatible-mode/v1
#   OpenAI 官方:  https://api.openai.com/v1
#   DeepSeek:    https://api.deepseek.com/v1
#   SiliconFlow: https://api.siliconflow.cn/v1
#   本地 vLLM:    http://localhost:8000/v1
LLM_API_KEY=REPLACE_ME
LLM_BASE_URL=https://openrouter.ai/api/v1

# 要评测的模型列表, 逗号分隔 (笛卡尔积: 每个模型都会跑所有题目 × 所有 sample).
# slug 必须是上面 LLM_BASE_URL 对应 provider 支持的原生 slug.
# 不要追加 ":online", 也不要启用任何 provider-native browsing.
#
# MODELS 示例:
#   OpenRouter:  openai/gpt-5,anthropic/claude-sonnet-4.5,google/gemini-2.5-pro,deepseek/deepseek-r1
#   阿里百炼:    qwen3-max,qwen-max,qwq-plus,deepseek-r1
#   OpenAI 官方: gpt-5,gpt-4o,o3,o4-mini
#   DeepSeek:   deepseek-chat,deepseek-reasoner
MODELS=openai/gpt-5,anthropic/claude-sonnet-4.5,google/gemini-2.5-pro,deepseek/deepseek-r1

# 模型训练截止日期: 题目 end_time <= cutoff 的 (q, model) 将被跳过并标记 skipped_training_cutoff.
# 格式: "<model_slug>=YYYY-MM-DD" 多组用逗号分隔. 未声明的模型不过滤.
# 请按你真实使用的模型自行核对截止日期.
MODEL_TRAINING_CUTOFFS=openai/gpt-5=2024-10-01,anthropic/claude-sonnet-4.5=2025-03-01,google/gemini-2.5-pro=2025-01-01,deepseek/deepseek-r1=2024-07-01

# LLM 调用参数
# max_tokens 已给足 reasoning + output 预算 (推理模型常消耗 3-8k reasoning tokens)
LLM_MAX_TOKENS=12000
LLM_TIMEOUT_S=240
LLM_TEMPERATURE=0.7
LLM_TOP_P=1.0

# 推理类模型 slug 子串列表 (大小写不敏感): 命中后调用时 **不传** temperature / top_p.
# 因为 OpenAI o-series / DeepSeek-R1 / Qwen QwQ 等推理模型对自定义采样参数会直接报 400.
# 若你用 OpenRouter 的 deepseek/deepseek-r1 也会命中 "r1", 正确被过滤.
LLM_REASONING_MODEL_PATTERNS=o1,o3,o4,r1,qwq

# LLM 并发 & 重试
# 并发先保守 (多数 provider 免费/基础档 ~60 RPM), 观察 429 后再调
LLM_MAX_CONCURRENCY=5
LLM_RETRY_MAX=5
LLM_BACKOFF_NETWORK_S=2,5,15,30,60
LLM_BACKOFF_RATE_LIMIT_S=10,30,60,120,300
LLM_BACKOFF_SERVER_5XX_S=5,15,30,60,120

# -------- Web Search Master Switch --------
# 网络搜索总开关. 默认 true = 将自制的 web_search 工具接入 ReAct 循环 (走 Tavily).
# 设为 false 时: LLM 请求不携带任何 tool schema, ReAct 退化为单步直答, Tavily
# 完全不被调用 (此模式下 TAVILY_API_KEY 可留占位符).
ENABLE_WEB_SEARCH=true

# -------- Tavily Search --------
TAVILY_API_KEY=tvly-REPLACE_ME
TAVILY_MAX_RESULTS=5

# Tavily search_depth (Tavily 官方文档定义的检索强度):
#   basic    — 1 credit/call, 标题 + content 摘要, 适合事实快查 (推荐, 默认)
#   advanced — 2 credits/call, 更长 content + 更高召回, 适合长尾事件
# 一次预测平均 3-5 次搜索, 默认 basic 控制 credits 消耗
TAVILY_SEARCH_DEPTH=basic

# Tavily include_raw_content: 是否返回页面正文以及格式
#   false    — 仅返回 ~1-2k chars/result 的摘要 (content 字段), 上下文最省
#   markdown — 完整页面 markdown (单 result 可达 40k+ chars), 信息最全 (默认)
#   text     — 完整页面纯文本, 约为 markdown 的 2/3
# 注: 单结果 raw_content 体积大, 务必同时设置 TAVILY_RAW_CONTENT_MAX_CHARS 截断
# 兼容: 旧值 true 等价于 markdown, 旧值 false 保持 false
TAVILY_INCLUDE_RAW_CONTENT=markdown

# 单结果 raw_content 截断长度 (chars). 仅在 TAVILY_INCLUDE_RAW_CONTENT != false 时生效.
# 0 = 不截断 (谨慎: 一次搜索 5 条结果总量可超 200k chars, 极易塞爆 LLM context)
# 8000 ≈ 单结果 ~2k tokens, 5 条 ≈ 10k tokens, 留出 reasoning + history 余量
TAVILY_RAW_CONTENT_MAX_CHARS=8000

# Tavily include_answer: Tavily 内部模型给出的速答 (评测纯度考量)
#   false    — 不返回 (默认, 推荐)
#              评测目的是测被测模型自己读 results 的判断力; 启用 answer 等于引入
#              "第二个 LLM" 的判断, 会压缩强弱模型间的差异, 污染评测结果
#   basic    — 一句话快速答案
#   advanced — 多段详细答案 (额外 credits)
TAVILY_INCLUDE_ANSWER=false

# end_date = question.end_time + offset. 项目默认 -1 (前一天, 避免事件当天信息泄露)
TAVILY_END_DATE_OFFSET_DAYS=-1

# Tavily 并发 & 重试
SEARCH_MAX_CONCURRENCY=5
SEARCH_RETRY_MAX=3
SEARCH_BACKOFF_S=2,5,15

# -------- ReAct Loop --------
# 一个 sample 内 LLM ↔ 系统的最大交互轮数. 启用反思协议或 nudge 后, 单题轮数会
# 比单步直答多 2-4 轮, 因此默认略大于历史值 (10 → 12).
REACT_MAX_STEPS=12
# 单 sample 内累计 web_search 次数硬上限. 超出后再调用工具会得到 'search budget
# exceeded'. 反思协议鼓励多角度检索, 但仍受这个预算约束防止账单失控.
REACT_MAX_SEARCH_CALLS=8

# 反思协议总开关 (推荐 true).
# 启用后会在 user prompt 末尾追加多步推理脚手架 (拆题 → 列 ≥3 检索角度 → 每次
# 搜索后反思 → 交叉验证 → 反方向自检 → 给出置信度), 用 prompt 工程把模型从
# "1 次搜索直接答" 拉到 "多角度检索 + 显式反思". 这是首选方法 — 不需要硬性
# 最低次数也能显著提升工具调用与思考深度.
# 注意: 协议文本不进 dataset_metadata, 因此 prompt_templates_hash 不变, 但完整
# 渲染后的 user message 会落入每条 sample 的 user_prompt 字段, 完全可复盘.
# 设 false 可回退到旧行为 (用于对照实验).
REACT_REFLECTION_PROTOCOL=true

# 软性最低搜索次数 (兜底, 默认关).
# 0 = 关闭. >0 = 当 LLM 试图给最终答案但累计 web_search 次数 < 该值时, 注入一条
# user nudge 让它继续检索一个新角度后再答. 仅在反思协议仍不足以驱动模型时启用,
# 例如某些拒绝多步推理的小模型. 受 REACT_MAX_SEARCH_CALLS 上限约束 (不能超过它).
# 推荐取值: 0 (默认, 让协议自然驱动) 或 2-3 (强制下限).
REACT_MIN_SEARCH_CALLS=0

# 单 sample 最多注入几次 nudge, 防止模型与系统反复 nudge 死循环. REACT_MAX_STEPS
# 仍是硬天花板. 0 = 完全禁用 nudge (等价于把 REACT_MIN_SEARCH_CALLS 设为 0).
REACT_MAX_NUDGES=2

# -------- Sampling --------
SAMPLING_N=5

# -------- Run / Resume --------
# 留空则自动生成 YYYYMMDD-HHMMSS-{4位短uuid}. 填相同的 run_id 可断点续跑
RUN_ID=
RESUME=true

# -------- Database --------
# SOURCE_DB: 题库 sqlite 文件路径. 仓库自带的示例数据集是 forecast_eval_set_example.db
# (319 道题, 2026-01-15 ~ 2026-04-14). 自带数据集时只要保持表 schema 一致即可换路径.
SOURCE_DB=./forecast_eval_set_example.db

# SOURCE_TABLE: SOURCE_DB 内部的题库表名. 仓库自带数据集为 forecast_eval_set_example;
# 自带数据集时这里改成你自己的表名即可 (loader 通过该参数动态选择 FROM 表).
# 表 schema 必须包含: id / choice_type / question_type / event / options / answer / end_time
# (字段含义见 FRAME.md §2.1). 表名只允许 SQLite 合法标识符 [A-Za-z_][A-Za-z0-9_]*,
# 防止 SQL 注入.
SOURCE_TABLE=forecast_eval_set_example

# 每次评测都会在 RUNS_ROOT 下创建独立的 {run_id}/ 子目录 (db/ / analysis/ / logs/).
# 每个模型在 db/ 下各占一个 sqlite 文件; 评测结束后统计结果写到 analysis/.
RUNS_ROOT=./runs
DB_COMMIT_BATCH=10
# false 不存完整 messages trace, 可减小 db 80% 体积
WRITE_MESSAGES_TRACE=true

# -------- Logging --------
LOG_LEVEL=INFO
LOG_DIR=./logs
